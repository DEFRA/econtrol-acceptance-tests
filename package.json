{
  "name": "econtrol-acceptance-tests",
  "version": "0.0.0",
  "type": "module",
  "description": "Sample WebdriverIO + Cucumber BDD + Allure reporting framework",
  "engines": {
    "node": ">=22.13.1"
  },
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:smoke": "wdio run wdio.conf.js --cucumberOpts.tagExpression='@CTS-585'",
    "test:headless": "HEADLESS=true wdio run wdio.conf.js",
    "report:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "report:open": "allure open ./allure-report",
    "report": "npm run report:generate && npm run report:open",
    "clean": "rm -rf allure-results allure-report"
  },
  "devDependencies": {
    "@axe-core/webdriverio": "^4.10.0",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/cucumber-framework": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "allure-commandline": "^2.29.0"
  }
}